# Copia este archivo a .streamlit/secrets.toml y rellena con tus credenciales
# NUNCA subas secrets.toml a GitHub

DATABASE_URL = "postgresql://postgres:[TU_PASSWORD]@[TU_HOST].supabase.co:5432/postgres"

# Contraseña de acceso a la app (Streamlit built-in auth)
# La clave vacía "" aplica a todos los usuarios
[passwords]
"" = "[TU_PASSWORD_APP]"
